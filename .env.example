# Application
APP_NAME=lolo-ai-documents
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Claude API (Anthropic) - REQUIRED
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MAX_TOKENS=8000
CLAUDE_TEMPERATURE=0.3

# Rate Limits by Model (Tier 1 defaults - adjust based on your tier)
# Sonnet 4.6
SONNET_RPM=50
SONNET_INPUT_TPM=40000
SONNET_OUTPUT_TPM=8000
# Haiku 4.5
HAIKU_RPM=50
HAIKU_INPUT_TPM=50000
HAIKU_OUTPUT_TPM=10000

# MySQL Database (shared with lolo-backend)
# Sessions are stored in JUDICIAL_AI_DOCUMENT_SESSION table
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=db_lolo

# Session TTL (4 hours, matches lolo-backend)
SESSION_TTL_SECONDS=14400

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-west-2
S3_BUCKET_NAME=archivosstorage
AWS_CHB_PATH=CHB/

# Rate Limiting
RATE_LIMIT_ANALYZE=10/minute
RATE_LIMIT_GENERATE=5/minute
RATE_LIMIT_REFINE=20/minute

# Timeouts (seconds)
TIMEOUT_ANALYZE=30
TIMEOUT_GENERATE=60
TIMEOUT_REFINE=45
TIMEOUT_FINALIZE=30

# CORS Origins (comma-separated for production)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5000"]

# Backend API (for learning system communication)
BACKEND_URL=http://localhost:5000
INTERNAL_API_KEY=change-this-to-a-strong-internal-key

# Learning System
LEARNING_ENABLED=true
LEARNING_MAX_PER_GENERATION=20
