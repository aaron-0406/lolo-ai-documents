# =============================================================================
# Docker Ignore File for lolo-ai-documents
# =============================================================================
# Excludes files from Docker build context to:
# - Speed up builds
# - Reduce image size
# - Prevent sensitive data from being included
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
tests/
test/
*_test.py
test_*.py
conftest.py
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# -----------------------------------------------------------------------------
# IDE and Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.md
!README.md
docs/
doc/
*.rst
*.txt
!requirements.txt

# -----------------------------------------------------------------------------
# Local configuration
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local
config.local.*
secrets/
credentials/

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
*.bak
*.swp
.cache/

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
docker-compose*.yaml
.docker/
.dockerignore

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Jenkinsfile
azure-pipelines.yml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
Makefile
*.make
scripts/
*.sh
!entrypoint.sh
LICENSE
CHANGELOG*
CONTRIBUTING*
AUTHORS*
HISTORY*

# -----------------------------------------------------------------------------
# Poetry (we export to requirements.txt in build)
# -----------------------------------------------------------------------------
poetry.lock
poetry.toml
